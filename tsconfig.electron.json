{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": "electron",
    "types": ["node"],
    "noEmit": false,
    "sourceMap": false
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["electron/**/*.test.ts"]
}
